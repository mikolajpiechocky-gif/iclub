# =====================================================================
# iClub Management — zmienne środowiskowe
# Skopiuj ten plik jako .env.local i uzupełnij prawdziwymi wartościami.
# Instrukcja krok po kroku: docs/SUPABASE_SETUP.md
# =====================================================================

# --- Supabase (wymagane do logowania i prawdziwych danych) ---
# Znajdziesz je w panelu Supabase: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Klucz service_role (OPCJONALNY, tylko lokalnie do migracji) ---
# NIE używany przez aplikację ani przeglądarkę. Trzymaj w tajemnicy.
# SUPABASE_SERVICE_ROLE_KEY=

# Uwaga: dopóki powyższe zmienne są puste, aplikacja działa w TRYBIE DEMO
# (logowanie wyłączone, dane demonstracyjne). Po uzupełnieniu i restarcie
# serwera automatycznie włącza się logowanie oraz odczyt/zapis z Supabase.
